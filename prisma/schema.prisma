// prisma/schema.prisma
// Court Reporting Workflow Manager — data model

generator client {
  provider = "prisma-client-js"
}

// ── Database configuration ────────────────────────────────────────────────────
// Currently set to SQLite for easy local development (no server needed).
// To switch to PostgreSQL, comment out the sqlite block and uncomment postgres.

datasource db {
  provider = "sqlite"
  // Connection URL configured in prisma.config.ts (Prisma v7 requirement)
}

// PostgreSQL (Prisma Postgres / any PG server):
// datasource db {
//   provider = "postgresql"
//   // Connection URL is configured in prisma.config.ts (Prisma v7 requirement)
// }

// ─── Enums ────────────────────────────────────────────────────────────────────
// Note: SQLite does not have native enums — Prisma maps them to Strings.

enum JobStatus {
  NEW
  ASSIGNED
  TRANSCRIBED
  REVIEWED
  COMPLETED
}

enum LocationType {
  PHYSICAL
  REMOTE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Job {
  id           String       @id @default(uuid())
  caseName     String
  durationMin  Int
  locationType LocationType
  // Required when locationType is PHYSICAL — used for reporter city-matching
  city         String?
  status       JobStatus    @default(NEW)

  reporterId String?
  reporter   Reporter? @relation(fields: [reporterId], references: [id])

  editorId String?
  editor   Editor?  @relation(fields: [editorId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reporter {
  id            String  @id @default(uuid())
  name          String
  city          String
  available     Boolean @default(true)
  ratePerMinute Int // IDR per minute, e.g. 2000

  jobs Job[]
}

model Editor {
  id        String  @id @default(uuid())
  name      String
  available Boolean @default(true)
  flatFee   Int // IDR flat fee per job, e.g. 50000

  jobs Job[]
}

model Payment {
  id             String   @id @default(uuid())
  jobId          String   @unique
  job            Job      @relation(fields: [jobId], references: [id])
  reporterPayout Int // IDR
  editorPayout   Int // IDR
  totalPayout    Int // IDR
  calculatedAt   DateTime @default(now())
}
